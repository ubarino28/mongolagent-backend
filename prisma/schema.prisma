generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model TuruuChat {
  id        String   @id @default(uuid())
  psid      String   @unique
  messages  Json     @default("[]")
  updatedAt DateTime @updatedAt
}

model TuruuLead {
  id              String   @id @default(uuid())
  psid            String
  name            String?
  phone           String?
  email           String?
  company         String?
  serviceInterest String?
  budget          String?
  status          String   @default("NEW")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TuruuConsultation {
  id              String   @id @default(uuid())
  psid            String
  name            String?
  phone           String?
  email           String?
  serviceInterest String?
  preferredTime   String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}
