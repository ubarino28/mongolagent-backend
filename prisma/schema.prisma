generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String   @id @default(uuid())
  name               String
  slug               String   @unique
  email              String   @unique
  passwordHash       String
  fbPageId           String?  @unique
  fbPageToken        String?
  instagramAccountId String?
  telegramBotToken   String?
  telegramChatId     String?
  logoUrl            String?
  qpayMerchantId     String?
  qpayBankCode       String?
  qpayAccountNumber  String?
  qpayAccountName    String?
  qpayBranchCode     String?
  subInvoiceId       String?
  subQpayStatus      String?
  plan                String   @default("starter")
  status              String   @default("active")
  messageUsed         Int      @default(0)
  quotaResetAt        DateTime?
  subscriptionEndsAt  DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  orders TuruuOrder[]
  store  Store?
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model EmailChangeToken {
  id        String   @id @default(uuid())
  orgId     String
  newEmail  String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TuruuChat {
  id               String   @id @default(uuid())
  psid             String
  orgId            String?
  messages         Json     @default("[]")
  blocked          Boolean  @default(false)
  handoffRequested Boolean   @default(false)
  handoffAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([orgId, psid])
}

model TuruuUnanswered {
  id        String   @id @default(uuid())
  orgId     String
  question  String
  psid      String?
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
}

model TuruuLead {
  id              String   @id @default(uuid())
  psid            String
  orgId           String?
  name            String?
  phone           String?
  email           String?
  company         String?
  serviceInterest String?
  budget          String?
  status          String   @default("NEW")
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TuruuConsultation {
  id              String   @id @default(uuid())
  psid            String
  orgId           String?
  name            String?
  phone           String?
  email           String?
  serviceInterest String?
  preferredTime   String?
  status          String   @default("PENDING")
  createdAt       DateTime @default(now())
}

model TuruuOrder {
  id              String       @id @default(uuid())
  orgId           String
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  deliveryAddress String?
  items           Json?
  totalAmount     Float?
  status          String       @default("NEW")
  notes           String?
  psid            String?
  qpayInvoiceId   String?
  qpayQrText      String?
  qpayUrls        Json?
  qpayStatus      String?      @default("PENDING")
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model TuruuSettings {
  id        String   @id @default(uuid())
  orgId     String?
  key       String
  value     String
  updatedAt DateTime @updatedAt

  @@unique([orgId, key])
}

model TuruuKnowledge {
  id        String   @id @default(uuid())
  orgId     String?
  question  String
  answer    String
  category  String?
  imageUrl  String?
  variants  Json?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TuruuStaff {
  id           String              @id @default(uuid())
  orgId        String
  name         String
  services     Json                @default("[]")
  workDays     Json                @default("[1,2,3,4,5]")
  workStart    String              @default("09:00")
  workEnd      String              @default("18:00")
  bufferMinutes Int                @default(0)
  isActive     Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  appointments TuruuAppointment[]
}

model TuruuAppointment {
  id              String      @id @default(uuid())
  orgId           String
  psid            String?
  staffId         String
  staff           TuruuStaff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  serviceName     String
  durationMinutes Int
  date            String
  timeSlot        String
  customerName    String?
  customerPhone   String?
  depositAmount   Float       @default(0)
  depositStatus   String      @default("NONE")
  qpayInvoiceId   String?
  qpayQrText      String?
  qpayUrls        Json?
  qpayStatus      String?
  status          String      @default("PENDING")
  notes           String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// ─────────────────────────────────────────────
// Website builder (Mongol Agent Website)
// ─────────────────────────────────────────────

model Store {
  id           String   @id @default(uuid())
  orgId        String   @unique
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  name         String
  slug         String   @unique          // subdomain: slug.mongolagent.mn
  customDomain String?  @unique          // хэрэглэгчийн өөрийн домэйн (Phase 4)
  status       String   @default("draft") // draft | published
  templateId   String?                    // сонгосон template
  theme        Json     @default("{}")    // өнгө, фонт, лого г.м
  currency     String   @default("MNT")
  phone        String?                     // footer холбоо барих
  email        String?
  address      String?
  delivery     Json     @default("{}")    // хүргэлтийн тохиргоо (төрөл, төлбөр, үнэгүй босго)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  pages     StorePage[]
  products  Product[]
  orders    StoreOrder[]
  discounts Discount[]
}

model StorePage {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  title     String
  path      String                       // "/", "/about", "/contact"
  type      String   @default("custom")  // home | about | contact | custom
  content   Json     @default("{}")      // Puck drag-and-drop блокууд
  published Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, path])
}

model Product {
  id             String   @id @default(uuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orgId          String
  name           String
  description    String?
  price          Float    @default(0)
  compareAtPrice Float?
  images         Json     @default("[]")
  stock          Int      @default(0)
  sku            String?
  category       String?
  active         Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Discount {
  id        String   @id @default(uuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orgId     String
  code      String                          // купон код (ихэвчлэн ТОМ үсгээр)
  type      String   @default("percent")    // percent | fixed
  value     Float    @default(0)            // 10 (=10%) эсвэл 5000 (=5000₮)
  minAmount Float    @default(0)            // доод захиалгын дүн
  maxUses   Int?                             // нийт ашиглах хязгаар (null = хязгааргүй)
  usedCount Int      @default(0)
  active    Boolean  @default(true)
  startsAt  DateTime?
  endsAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, code])
}

model StoreOrder {
  id              String   @id @default(uuid())
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orgId           String
  customerName    String?
  customerPhone   String?
  customerEmail   String?
  deliveryAddress String?
  items           Json     @default("[]") // сагсны бараанууд
  totalAmount     Float    @default(0)
  discountCode    String?                   // хэрэглэсэн купон код
  discountAmount  Float    @default(0)      // хямдруулсан дүн
  deliveryMethod  String?                   // inUB | countryside | pickup
  deliveryFee     Float    @default(0)      // хүргэлтийн төлбөр
  status          String   @default("NEW") // NEW | PAID | SHIPPED | DONE | CANCELLED
  notes           String?
  qpayInvoiceId   String?
  qpayQrText      String?
  qpayUrls        Json?
  qpayStatus      String?  @default("PENDING")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
